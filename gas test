-- Complete Roblox Baseball Auto-Swing Script

local replicatedStorage = game:GetService('ReplicatedStorage')
local players = game:GetService('Players')
local player = players.LocalPlayer
local UIS = game:GetService('UserInputService')
local RemoteEvent = replicatedStorage:WaitForChild('AutoSwingEvent')

-- Variables
local perfectTimingThreshold = 0.1 -- adjust this value based on testing results
local isSwinging = false
local timingCalculation = 0

-- Temporary UI
local screenGui = Instance.new('ScreenGui', player:WaitForChild('PlayerGui'))
local unloadButton = Instance.new('TextButton')

unloadButton.Size = UDim2.new(0, 200, 0, 50)
unloadButton.Position = UDim2.new(0.5, -100, 0.5, -25)
unloadButton.Text = 'Unload Script'
unloadButton.Parent = screenGui

unloadButton.MouseButton1Click:Connect(function()
    screenGui:Destroy()
    isSwinging = false
end)

-- Frame-Perfect Swing Detection
function onPitchedBall() 
    local currentTime = tick()
    if not isSwinging then
        timingCalculation = currentTime
        isSwinging = true
    else
        local swingTiming = currentTime - timingCalculation
        if swingTiming <= perfectTimingThreshold then
            RemoteEvent:FireServer('Swing')
        end
        isSwinging = false
    end
end

-- Connect to the event for pitched ball (you might need to setup your game event properly)
replicatedStorage.PitchedBall.Event:Connect(onPitchedBall) 

-- Notes:
-- Adjust timingThreshold for best results based on gameplay experience.